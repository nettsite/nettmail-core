{
    "name": "nettsite/nettmail-core",
    "description": "NettMail core package - framework-agnostic email sending, contacts, lists, segments, bounce handling and template compilation",
    "keywords": [
        "nettmail",
        "core"
    ],
    "homepage": "https://github.com/nettsite/nettmail-core",
    "license": "MIT",
    "authors": [
        {
            "name": "Nettsite",
            "email": "nettsitesa@gmail.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "psr/http-client": "^1.0",
        "psr/http-factory": "^1.1",
        "psr/http-message": "^2.0",
        "symfony/mailer": "^7.2|^8.1"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.21.1",
        "nyholm/psr7": "^1.8",
        "pestphp/pest": "^4.0",
        "phpstan/phpstan": "^2.2"
    },
    "autoload": {
        "psr-4": {
            "Nettsite\\NettMail\\Core\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Nettsite\\NettMail\\Core\\Tests\\": "tests"
        }
    },
    "scripts": {
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage",
        "phpstan": "vendor/bin/phpstan analyse",
        "format": "vendor/bin/php-cs-fixer fix --config=.php-cs-fixer.dist.php --allow-risky=yes"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
